# ─── Dignity Institutional Platform — Environment Configuration ───────────────
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.

# ─── Database ─────────────────────────────────────────────────────────────────
# Dignity-specific DB — separate from any other repo
# Local port 5442 maps to the dignity_institutional database
DATABASE_URL="postgresql://postgres:postgres@localhost:5442/dignity_institutional?schema=public"

# ─── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="CHANGE_ME_min_32_chars_random_string"
NEXTAUTH_URL="http://localhost:3300"

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local port 6382 — dignity-dedicated instance
REDIS_URL="redis://localhost:6382"
REDIS_KEY_PREFIX="dignity:"

# ─── Blockchain RPC ───────────────────────────────────────────────────────────
# Local hardhat chain on port 8646; swap for mainnet/testnet as needed
ETH_RPC_URL="http://localhost:8646"
CHAIN_ID="31337"

# ─── Contract Addresses (filled after deployment) ─────────────────────────────
CANONICAL_SECURITY_TOKEN_ADDRESS=""
IDENTITY_REGISTRY_ADDRESS=""
COMPLIANCE_REGISTRY_ADDRESS=""
ISSUANCE_CONTROLLER_ADDRESS=""
REDEMPTION_CONTROLLER_ADDRESS=""
ROLE_MANAGER_ADDRESS=""
TIMELOCK_ADMIN_ADDRESS=""
RESERVE_PROOF_ANCHOR_ADDRESS=""

# ─── KYC Provider ─────────────────────────────────────────────────────────────
KYC_PROVIDER="synaps"   # synaps | sumsub | manual
KYC_PROVIDER_KEY=""
KYC_WEBHOOK_SECRET=""

# ─── Document Storage (object storage abstraction) ────────────────────────────
STORAGE_PROVIDER="local" # local | s3 | azure
STORAGE_LOCAL_PATH="./tmp/uploads"
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ─── Email / Notifications ────────────────────────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
NOTIFICATION_FROM_ADDRESS="noreply@dignity.example.com"

# ─── Feature Flags ────────────────────────────────────────────────────────────
DEMO_MODE="true"          # show mock data instead of live data
SEED_MODE="false"         # seed DB on startup (dev only)
LOG_LEVEL="info"          # debug | info | warn | error

# ─── App Identity ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Dignity"
NEXT_PUBLIC_APP_DOMAIN="dignity.example.com"
NEXT_PUBLIC_TOKEN_SYMBOL="DIGAU"
NEXT_PUBLIC_DEMO_MODE="true"

{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir":   "src",
    "outDir":    "dist",
    "module":    "ESNext",
    "moduleResolution": "bundler",
    "target":    "ES2022",
    "strict":    true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}

{
  "name": "@dignity/db",
  "version": "0.1.0",
  "private": true,
  "description": "Dignity — Prisma database client and migrations",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
